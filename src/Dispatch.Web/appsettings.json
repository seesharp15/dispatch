{
  "Storage": {
    "RootPath": "data",
    "DatabasePath": "data/dispatch.db",
    "RecordingsPath": "data/recordings"
  },
  "Segmentation": {
    "ActivationDeltaDb": 10,
    "SilenceDeltaDb": 3,
    "InitialNoiseFloorDb": -55,
    "NoiseFloorEmaAlpha": 0.08,
    "HangoverSeconds": 2,
    "MinimumRecordingSeconds": 1,
    "PreRollSeconds": 1
